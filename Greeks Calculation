import numpy as np
import matplotlib.pyplot as plt
import pandas as pd
import os
from py_vollib.black_scholes.greeks.analytical import delta, gamma, vega, theta, rho

# Find data on my os
script_dir = os.path.dirname(os.path.abspath(__file__))
data_path = os.path.join(script_dir, '..', 'data', 'GOOGL_prices_5y_1d.csv')
#Change name of the firm if wanted and downloaded

stock_data = pd.read_csv(data_path, skiprows=1)

stock_prices = stock_data.iloc[:, 1].astype(float)  # Get the 2nd column, Price here

log_returns = np.log(stock_prices / stock_prices.shift(1)).dropna()

trading_days_year = 252
volatility = log_returns.std() * np.sqrt(trading_days_year)  # Annualized volatility

S = stock_prices.iloc[-1]  #From data downloaded
K = 150  # Strike price
T = 30/365  # Time to expiration (30 days)
r = 0.05  # Risk-free rate
sigma = volatility  # Calculated

# Calculate Greeks for a call option
call_delta = delta('c', S, K, T, r, sigma) #Derive relative to the underlying
call_gamma = gamma('c', S, K, T, r, sigma) #Derive relative to the underlying twice
call_vega = vega('c', S, K, T, r, sigma) #Derive relative to the volatility
call_theta = theta('c', S, K, T, r, sigma) #Derive relative to the time
call_rho = rho('c', S, K, T, r, sigma) #Derive relative to the risk-free rate


print(f"Call Delta: {call_delta}")
print(f"Call Gamma: {call_gamma}")
print(f"Call Vega: {call_vega}")
print(f"Call Theta: {call_theta}")
print(f"Call Gamma: {call_rho}")
